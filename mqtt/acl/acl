# ─── ACL File — Topic Access Control ─────────────────────────
# Controls which topics each user can publish and subscribe to
# Used with mosquitto_secure.conf only
# File has NO extension — save as plain file named "acl"
# ─────────────────────────────────────────────────────────────

user testuser
topic readwrite capstone/#
topic readwrite esp32/#
topic readwrite arm/#
topic readwrite pico2/#
topic read $SYS/#
